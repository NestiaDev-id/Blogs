{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "framework": "rust" 
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
