{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "vite"
        },
        "backend": {
            "root": "backend"
        }
    },
    "rewrites": [
        {
            "source": "/api",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/api/(.*)",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/((?!api).*)" ,
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
