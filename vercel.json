{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "framework": "rust" 
        }
    },
    "rewrites": [
    {
        "source": "/api/:path*",
        "destination": {
            "type": "service",
            "service": "backend",
            "path": "/:path*"
        }
    },
    {
        "source": "/:path*",
        "destination": {
            "type": "service",
            "service": "frontend"
        }
    }
    ]

}
